[layer_names]

3d_physics/layer_1="terrain"
3d_physics/layer_2="physics items"

[physics]

common/physics_ticks_per_second=240
common/max_physics_steps_per_frame=32
common/physics_jitter_fix=0.1
3d/physics_engine="Jolt Physics"
jolt_physics_3d/simulation/velocity_steps=4
jolt_physics_3d/simulation/position_steps=4
jolt_physics_3d/limits/temporary_memory_buffer_size=64
